{
  "name": "Noir & Blanc — Dark",
  "$schema": "vscode://schemas/color-theme",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable": "#E8E8E8",
    "variable.readonly": "#BDBDBD",
    "parameter": "#D4D4D4",
    "property": "#C8C8C8",
    "property.readonly": "#AAAAAA",
    "function": "#FFFFFF",
    "method": "#FFFFFF",
    "class": "#FFFFFF",
    "interface": "#E0E0E0",
    "type": "#D0D0D0",
    "namespace": "#BBBBBB",
    "module": "#CCCCCC",
    "keyword": "#FFFFFF",
    "string": "#999999",
    "number": "#BBBBBB",
    "comment": "#555555",
    "decorator": "#AAAAAA",
    "enumMember": "#CCCCCC"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#505050",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.other.important"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage",
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#E0E0E0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#909090"
      }
    },
    {
      "name": "String escape",
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#C0C0C0"
      }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric", "constant.other.color"],
      "settings": {
        "foreground": "#B8B8B8"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#CCCCCC",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "name": "Classes and Types",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.name.type.class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#E8E8E8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Interface names",
      "scope": ["entity.name.type.interface"],
      "settings": {
        "foreground": "#D8D8D8",
        "fontStyle": "italic bold"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#D8D8D8"
      }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#C8C8C8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Object Properties",
      "scope": [
        "variable.other.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#BBBBBB"
      }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#888888"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#666666"
      }
    },
    {
      "name": "HTML Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "HTML Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#AAAAAA",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS Properties",
      "scope": ["support.type.property-name.css", "meta.property-name.css"],
      "settings": {
        "foreground": "#CCCCCC"
      }
    },
    {
      "name": "CSS Values",
      "scope": ["meta.property-value.css", "support.constant.property-value.css"],
      "settings": {
        "foreground": "#999999"
      }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#E0E0E0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "CSS Units and Numbers",
      "scope": ["constant.numeric.css", "keyword.other.unit.css"],
      "settings": {
        "foreground": "#AAAAAA"
      }
    },
    {
      "name": "Markdown Headings",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": {
        "foreground": "#FFFFFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#EEEEEE",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#CCCCCC",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Code",
      "scope": ["markup.inline.raw", "markup.raw.block"],
      "settings": {
        "foreground": "#888888"
      }
    },
    {
      "name": "Markdown Links",
      "scope": ["markup.underline.link", "meta.link"],
      "settings": {
        "foreground": "#999999",
        "fontStyle": "underline"
      }
    },
    {
      "name": "JSON Keys",
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#CCCCCC"
      }
    },
    {
      "name": "JSON Values",
      "scope": ["string.quoted.double.json"],
      "settings": {
        "foreground": "#999999"
      }
    },
    {
      "name": "Import/Export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type Annotations",
      "scope": [
        "meta.type.annotation",
        "entity.name.type.alias",
        "entity.name.type.enum"
      ],
      "settings": {
        "foreground": "#C0C0C0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Decorators / Annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#777777",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": {
        "foreground": "#FFFFFF",
        "fontStyle": "bold underline"
      }
    }
  ],
